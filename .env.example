# Application metadata
APP_NAME=Documentation Chatbot API
APP_ENV=development

# Manual Streamlit test UI
CHATBOT_API_URL=http://localhost:8000

# Comma-separated browser origins. Leave empty to allow no cross-origin browsers.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Document chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# Embeddings and local vector storage
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-5.6-luna
OPENAI_REQUEST_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=2
CHROMA_PERSIST_DIRECTORY=data/chroma
CHROMA_COLLECTION_NAME=documentation
RETRIEVAL_TOP_K=4

# Document management
DOCUMENTS_DIRECTORY=data/documents
DOCUMENT_REGISTRY_PATH=data/document-registry.json
MAX_DOCUMENT_SIZE_BYTES=10485760

# Conversation memory (in-process, bounded)
MAX_CONVERSATION_TURNS=6
MAX_CONVERSATIONS=1000

# Operational safeguards
LOG_LEVEL=INFO
